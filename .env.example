# Server Configuration
PORT=8080

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/resumeforge
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# JWT Configuration
APP_JWT_SECRET=your-256-bit-secret-key-change-this-in-production

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
APP_SITE_URL=https://www.resumeforgeai.site
APP_SITE_NAME=ResumeForge AI

# CORS Configuration
APP_CORS_ALLOWED_ORIGIN=https://resumeforgeai.site,https://www.resumeforgeai.site

# Razorpay Payment Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_PAYMENT_LINK=your_payment_link
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key
MAIL_FROM_EMAIL=support@resumeforgeai.site
MAIL_FROM_NAME=ResumeForge AI
CONTACT_RECEIVER_EMAIL=admin@resumeforgeai.site
