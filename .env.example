# ════════════════════════════════════════════════════
#  ResumeForge AI — Backend Environment Variables
#  Copy to .env for local dev; add to Render for production
# ════════════════════════════════════════════════════

# ── Database (Render PostgreSQL) ──────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR-HOST.render.com:5432/YOUR_DB_NAME
SPRING_DATASOURCE_USERNAME=YOUR_DB_USER
SPRING_DATASOURCE_PASSWORD=YOUR_DB_PASSWORD

# ── Frontend URL (Vercel) ─────────────────────────────
# No trailing slash. Used for CORS.
FRONTEND_URL=https://your-app.vercel.app

# ── JWT Secret ────────────────────────────────────────
# Must be ≥32 chars. Generate: openssl rand -hex 32
APP_JWT_SECRET=replace-with-a-64-char-random-hex-string-never-commit-this

# ── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET
RAZORPAY_PAYMENT_LINK=https://rzp.io/rzp/YOUR_LINK_ID

# ── Razorpay Webhook Secret ───────────────────────────
# Razorpay Dashboard → Webhooks → your endpoint → Secret field
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
